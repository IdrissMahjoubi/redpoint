{% extends 'back_base.html.twig' %}

{% block body %}
    <div class="card-body">
        <h4 class="header-title">Modifier Video</h4>
        <p class="text-muted font-14">
            tous les champs sont obligatoires.
        </p>

        {{ form_start(form) }}

        <div class="form-group row">
            <div class="col-sm-10">
                {{ form_widget(form.name,{ 'attr': {'class' : 'form-control','placeholder' : 'titre'} }) }}
            </div>
        </div>

        <div class="form-group row">
            <div class="col-sm-10">
                <div class="input-group">
                    <div class="custom-file">
                {{ form_widget(form.image.imageFile,{'attr': {'class': 'form-control input-rounded'} }) }}
                    </div>
                </div>
            </div>
        </div>





        <div class="form-group row">
            <div class="col-sm-10">
                <div class="card">
                    <div class="card-body">
                        <img width="300" src="{{ asset('/uploads/'~ video.image.imageName) }}" alt="VIDEO">
                    </div> <!-- end card-body-->
                </div> <!-- end card-->
            </div>
        </div>
        <input type="submit" class="btn btn-primary" value="Valider">


        {{ form_end(form) }}


    </div>
{% endblock %}



