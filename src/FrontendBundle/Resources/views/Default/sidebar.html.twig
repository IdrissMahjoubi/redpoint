<div class="col-sm-3">
    <div class="left-sidebar">
        <h2>Category</h2>

        <div class="panel-group category-products" id="accordion">
            <!--category-productsr-->
            {%  for category in categories %}
                {% if category.subCategory|length == 0 %}
                    <div class="panel panel-default">
                    <div class="panel-heading">
                    <h4 class="panel-title"><a href="{{ path('get_by_category',{'id':category.id}) }}">{{ category.name }}</a></h4>
                    </div>
                    </div>
                {% else %}
                    <div class="panel panel-default">
                    <div class="panel-heading">
                    <h4 class="panel-title">
                        <a data-toggle="collapse" data-parent="#accordion" href="#category{{ category.id }}">
                            <span class="badge pull-right"><i class="fa fa-plus"></i></span>
                            {{ category.name }}
                        </a>
                    </h4>

                </div>
                <div id="category{{ category.id }}" class="panel-collapse collapse">
                    <div class="panel-body">
                        <ul>
                            {% for sub in category.subCategory %}
                            <li><a href="{{ path('get_by_sub_category',{'id':sub.id}) }}">{{ sub.name }} </a></li>
                            {% endfor %}
                        </ul>
                    </div>
                </div>
            </div>
                {% endif %}

            {% endfor %}


        </div>
        <!--/category-products-->



        <!--shipping-->
        <div class="shipping text-center mb-4">
        <img src="{{ asset('uploads/'~publicity.image.url)}}" alt="{{ publicity.name }}" />
        </div>
        <!--/shipping-->
    </div>
</div>


