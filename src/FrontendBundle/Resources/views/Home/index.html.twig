{% extends "base.html.twig" %}
{% block body %}


    <section id="slider"><!--slider-->
        <div class="container">
            <div class="row">
                <div class="col-sm-12">
                    <div id="slider-carousel" class="carousel slide" data-ride="carousel">
                        <ol class="carousel-indicators">
                            <li data-target="#slider-carousel" data-slide-to="0" class="active"></li>
                            <li data-target="#slider-carousel" data-slide-to="1"></li>
                            <li data-target="#slider-carousel" data-slide-to="2"></li>
                        </ol>

                        <div class="carousel-inner">
                            <div class="item active">
                                <div class="col-sm-6">
                                    <img src="{{ asset('uploads/'~sliderOne.image.url)}}" class="girl img-responsive" alt="" />
                                </div>
                                <div class="col-sm-6">
                                    <h1>{{ sliderOne.name }}</h1>
                                    <h2>{{ sliderOne.description }}</h2>
                                    <p>{{ sliderOne.description2 }}</p>
                                </div>

                            </div>
                            <div class="item">
                                <div class="col-sm-6">
                                    <img src="{{ asset('uploads/'~sliderTwo.image.url)}}" class="girl img-responsive" alt="" />
                                </div>
                                <div class="col-sm-6">
                                    <h1>{{ sliderTwo.name }}</h1>
                                    <h2>{{ sliderTwo.description }}</h2>
                                    <p>{{ sliderTwo.description2 }}</p>
                                </div>

                            </div>

                            <div class="item">
                                <div class="col-sm-6">
                                    <img src="{{ asset('uploads/'~sliderThree.image.url)}}" class="girl img-responsive" alt="" />
                                </div>

                                <div class="col-sm-6">
                                    <h1>{{ sliderThree.name }}</h1>
                                    <h2>{{ sliderThree.description }}</h2>
                                    <p>{{ sliderThree.description2 }}</p>
                                </div>

                            </div>

                        </div>

                        <a href="#slider-carousel" class="left control-carousel hidden-xs" data-slide="prev">
                            <i class="fa fa-angle-left"></i>
                        </a>
                        <a href="#slider-carousel" class="right control-carousel hidden-xs" data-slide="next">
                            <i class="fa fa-angle-right"></i>
                        </a>
                    </div>

                </div>
            </div>
        </div>
    </section><!--/slider-->

    <section>
        <div class="container">
            <div class="row">
            {% include('@Frontend/Default/sidebar.html.twig') %}
                <div class="col-sm-9 padding-right">
                    <div class="features_items"><!--features_items-->
                        <h2 class="title text-center">Featured Items</h2>
                        {%  for product in products %}
                        <div class="col-sm-4">
                            <div class="product-image-wrapper">
                                <div class="single-products">
                                    <div class="productinfo text-center">
                                        <img src="{{ asset('uploads/'~product.images[0].url)}}" alt="" />
                                        <h2>{{ product.price }} KWD</h2>
                                        <p>{{  product.name}}</p>
                                        <a href="{{ path('front_product',{ 'id': product.id }) }}" class="btn btn-default add-to-cart"><i class="fa fa-shopping-cart"></i>View Item</a>
                                    </div>
                                    <div class="product-overlay">
                                        <div class="overlay-content">
                                            <h2>{{ product.price }} KWD</h2>
                                            <p>{{ product.description }}</p>
                                            <a href="{{ path('front_product',{ 'id': product.id }) }}" class="btn btn-default add-to-cart"><i class="fa fa-shopping-cart"></i>View Item</a>
                                        </div>
                                    </div>
                                </div>
                                {% if is_granted('IS_AUTHENTICATED_FULLY') %}
                                <div class="choose">
                                    <ul class="nav nav-pills nav-justified">
                                        <li><a href="{{ path('front_wishlist_add',{ 'id': product.id }) }}"><i class="fa fa-plus-square"></i>Add to wishlist</a></li>
                                    </ul>
                                </div>
                                {% endif %}
                            </div>
                        </div>
                        {% endfor %}
                    </div>
                    <div class="row">
                        {# display navigation #}
                        <div class="navigation">
                            {{ knp_pagination_render(products) }}
                        </div>
                    </div>
                </div>
            </div>
        </div>


    </section>



{% endblock %}

