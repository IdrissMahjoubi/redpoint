{% extends "base.html.twig" %}
{% block body %}

    <section id="advertisement">
        <div class="container">
            <img src="{{ asset('assets/images/shop/advertisement.jpg') }}" alt=""/>
        </div>
    </section>

    <section>
        <div class="container">
            <div class="row">
                {% include('@Frontend/Default/sidebar.html.twig') %}

                <div class="col-sm-8 padding-right">
                    <div class="features_items"><!--features_items-->
                        <h2 class="title text-center">Features Items</h2>
                            {% for company in companies %}
                        <div class="col-sm-4">
                            <div class="product-image-wrapper">
                                <div class="single-products">
                                    <div class="productinfo text-center">
                                        <img src="{{ asset('uploads/'~company.image.url)}}" alt="">
                                        <h2>{{  company.companyName}}</h2>
                                        <p>{{ company.about}}</p>
                                        <a href="{{ path('front_products_by_shop',{'id':company.id}) }}" class="btn btn-default add-to-cart"><i
                                                    class="fa fa-shopping-cart"></i>go to products</a>
                                    </div>
                                </div>
                                <div class="choose">
                                    <ul class="nav nav-pills nav-justified">
                                        <li><a href=""><i class="fa fa-plus-square"></i>Add to wishlist</a></li>
                                        <li><a href=""><i class="fa fa-plus-square"></i>Add to compare</a></li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                        {% endfor %}
                    </div><!--features_items-->
                    <ul class="pagination">
                        <li class="active"><a href="">1</a></li>
                        <li><a href="">2</a></li>
                        <li><a href="">3</a></li>
                        <li><a href="">&raquo;</a></li>
                    </ul>
                </div>
            </div>
        </div>
    </section>


{% endblock %}