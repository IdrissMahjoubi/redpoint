{% extends 'base.html.twig' %}

{% block body %}
    <section id="form"><!--form-->
        <div class="container">
            <div class="row">
                <div class="col-sm-8">
                    <div class="login-form"><!--login form-->
                        <h2>Make a post</h2>
                            {{ form_start(form) }}
                            {{ form_widget(form.images.vars.prototype.imageFile)}}
                            <button type="submit" class="btn btn-default">Post</button>
                            {{ form_end(form) }}
                    </div><!--/login form-->
                </div>
            </div>
        </div>
    </section><!--/form-->
{% endblock %}

