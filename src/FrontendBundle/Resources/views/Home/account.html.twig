{% extends 'base.html.twig' %}

{% block body %}
    <section id="account"><!--form-->
        <div class="container">
            <div class="row">
                <div class="col-sm-4 col-sm-offset-1">
                    <div class="signup-form">
                    <h2>تفاصيل الحساب</h2>
                        <ul>
                            <li>
                            <label>اسم المستخدم </label>
                                <p>{{ user.username }}</p>
                            </li>
                            <li>
                                <label>البريد الإلكتروني</label>
                                <p>{{ user.email }}</p>
                            </li>
                            <li>
                                <label>الحزمة</label>
                                <p>{{ user.package }}</p>
                            </li>

                        </ul>
                        <form action="{{ path('profile_edit') }}">
                        <button type="submit" class="btn btn-default">
                            تعديل الحساب
                        </button>
                        </form>
                    </div>
                </div>
                <div class="col-sm-1">
                    <h2 class="or"></h2>
                </div>
                <div class="col-sm-4">
                    <div class="signup-form">
                        {% if NumberOfProductsLeft == 0 %}
                        <h2> لم يعد بإمكانك النشر ..<a href="{{ path('front_contact') }}">ترقية الآن</a></h2>
                        {% else %}
                            <h2>بيع المنتج الخاص بك في أيام ..</h2>
                        {% endif %}
                        <form action="{{ path('front_post_product') }}">
                            <button type="submit" class="btn btn-default">نشر صفقة</button>
                        </form>
                    </div>
                    <div class="signup-form">
                        <h2>تحقق من كل مشاركاتك</h2>
                        <form action="{{ path('front_my_products') }}">
                            <button type="submit" class="btn btn-default">مشاركاتي</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </section><!--/form-->
{% endblock %}

