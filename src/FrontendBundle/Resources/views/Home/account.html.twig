{% extends 'base.html.twig' %}

{% block body %}
    <section id="account"><!--form-->
        <div class="container">
            <div class="row">
                <div class="col-sm-4 col-sm-offset-1">
                    <div class="login-form"><!--login form-->
                        <h2>Account Details</h2>
                        <ul>
                            <li>
                            <label>Username: </label>
                                <p>{{ user.username }}</p>
                            </li>
                            <li>
                                <label>E-mail: </label>
                                <p>{{ user.email }}</p>
                            </li>
                            <li>
                                <label>Your package: </label>
                                <p>Silver</p>
                            </li>
                            <li>
                                <label>Name: </label>
                                <p>Idriss</p>
                            </li>


                            <button type="submit" class="btn btn-default">
                                <a href="{{ path('fos_user_profile_edit') }}">Edit Account</a>
                                </button>
                        </ul>
                    </div><!--/login form-->
                </div>
                <div class="col-sm-1">
                    <h2 class="or"></h2>
                </div>
                <div class="col-sm-4">
                    <div class="signup-form">
                        <h2>Sell your product in days ..</h2>
                        <form action="{{ path('front_post_product') }}">
                            <button type="submit" class="btn btn-default">POST A DEAL</button>
                        </form>
                    </div>
                    <div class="signup-form">
                        <h2>check all your posts</h2>
                        <form action="{{ path('front_my_products') }}">
                            <button type="submit" class="btn btn-default">My posts</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </section><!--/form-->
{% endblock %}

