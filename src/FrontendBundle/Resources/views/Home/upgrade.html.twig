{% extends "base.html.twig" %}

{% block body %}

    <section id="cart_items">
        <div class="container">

            <div class="step-one">
                <h2 class="heading">حزمة الترقية</h2>
            </div>
            <div class="checkout-options">
                <h3>اختيار حزمة الخاص بك</h3>
                <p> أو اتصل بنا مباشرة<a href="{{ path('front_contact') }}">   هنا </a></p>
            </div><!--/checkout-options-->

            <div class="review-payment">
                <h2>التسعير</h2>
            </div>

            <div class="table-responsive cart_info">
                <table class="table table-condensed">
                    <thead>
                    <tr class="cart_menu">
                        <td>الاسم</td>
                        <td>السعر</td>
                        <td>عدد المنتجات</td>
                        <td>مزايا</td>
                        <td></td>
                    </tr>
                    </thead>
                    <tbody>
                    {% for item in pricings %}
                    <tr>
                        <td>
                            {{ item.name }}
                        </td>

                        <td>
                            {{ item.price }}
                        </td>
                        <td>
                            {{ item.numberOfPosts }}
                        </td>

                        <td>
                            {{ item.advantages }}
                        </td>



                        <td>
                                <a class="dropdown-item" href="{{ path('front_contact') }}">اختار</a>
                        </td>
                    </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>

        </div>
    </section> <!--/#cart_items-->


{% endblock %}