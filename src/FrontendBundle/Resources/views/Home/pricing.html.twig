{% extends "base.html.twig" %}
{% block body %}

<div class="push-top"></div>
<section class="section-intro bg-img bg11 stellar" data-stellar-background-ratio="0.4">
    <div class="bg-overlay op6"></div>
    <div class="container">
        <div class="row">
            <div class="col-md-5 col-sm-8">
                <h1 class="intro-title mb20">Pricing</h1>
                <p class="intro-p mb30">Lorem ipsum dolor sit amet, consectetur adipisicing elit. Sit tenetur reiciendis molestias nostrum excepturi porro dolorum amet!</p>
            </div>
        </div>
    </div>
</section>
<div class="page-breadcrumbs-wrapper pb2">
    <div class="container">
        <div class="row">
            <div class="col-sm-12">
                <div class="pull-right">
                    <div class="page-breadcrumbs">
                        <a href="#">home</a> <span class="separator"> / </span> <a href="#">pages</a> <span class="separator"> / </span> <a href="#" class="active">pricing</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<section class="section mt30">
    <div class="container">
        <div class="row">
            <div class="col-sm-12">
                <div class="plans">
                    <div class="row col-p0">
                        {% for pricing in pricings %}
                        <div class="col-sm-4">
                            <div class="plan plan-basic">
                                <div class="plan-header">
                                    <h3 class="plan-price">
                                        <span class="plan-curency">$</span>{{ pricing.price }}<span class="plan-period">/ month</span>
                                    </h3>
                                    <h2 class="plan-title">{{ pricing.name }}</h2>
                                </div>
                                <div class="clearfix">
                                    <ul class="plan-features">
                                        <li>lorem</li>

                                    </ul>
                                </div>
                                <button onclick="readValue()" id="account_type" value="{{ pricing.name}}"><a
                                            href="{{ path('fos_user_registration_register'),  }}">Create
                                        account</a></button>                            </div>
                        </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
    <script>
        function readValue() {
            var x = localStorage.setItem("account_type",document.getElementById("account_type").value);
        }
        /*document.getElementById("demo").valueOf()
        localStorage.setItem('account_type', account_type.value);*/
    </script>
{% endblock %}