{% extends 'back_base.html.twig' %}
{% trans_default_domain 'back' %}

{% block body %}
    <div class="card-body">
        <h4 class="header-title">Ajouter</h4>
        <p class="text-muted font-14">
            tous les champs sont obligatoires.
        </p>

        {{ form_start(form) }}

        <div class="form-group row">
            <div class="col-sm-10">
                {% set title = 'Titre'|trans %}
                {{ form_widget(form.name,{ 'attr': {'class' : 'form-control','placeholder' : title } }) }}
            </div>
        </div>
        <div class="form-group row">
            <div class="col-sm-10">
                {% set first = '1ere description'|trans %}
                {{ form_widget(form.description,{ 'attr': {'class': 'form-control input-rounded','placeholder' : first,'rows':'5'} }) }}

            </div>
        </div>

        {{ form_widget(form.description2,{ 'attr': {'class': 'form-control input-rounded','hidden' : 'true','rows':'5'} }) }}


        <div class="form-group row">
            <div class="col-sm-10">

                {{ form_widget(form.filter,{ 'attr': {'class': 'form-control input-rounded','rows':'5'} }) }}
            </div>
        </div>
        <div class="form-group row">
            <div class="col-sm-10">
                <div class="input-group">
                    <div class="custom-file">
                        {{ form_widget(form.image.imageFile,{'attr': {'class': 'form-control input-rounded'} }) }}
                    </div>
                </div>
            </div>
        </div>

        <input type="submit" class="btn btn-block btn-primary" value="Valider">

        {{ form_end(form) }}

    </div>
{% endblock %}



