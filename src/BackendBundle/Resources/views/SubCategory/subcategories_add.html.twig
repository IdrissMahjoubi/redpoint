{% extends 'back_base.html.twig' %}
{% trans_default_domain 'back' %}

{% block body %}
    <div class="card-body">
        <h4 class="header-title">Ajouter</h4>
        <p class="text-muted font-14">
            tous les champs sont obligatoires.
        </p>

        {{ form_start(form) }}

        <div class="form-group row">
            <div class="col-sm-10">
                {{ form_widget(form.name,{ 'attr': {'class' : 'form-control','placeholder' : 'Name' } }) }}
            </div>
        </div>
        <div class="form-group row">
            <div class="col-sm-10">
                {{ form_widget(form.category,{ 'attr': {'class' : 'form-control','placeholder' : 'category' } }) }}
            </div>
        </div>

        <input type="submit" class="btn btn-block btn-primary" value="Valider">

        {{ form_end(form) }}

    </div>
{% endblock %}



