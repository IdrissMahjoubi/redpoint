{% trans_default_domain 'FOSUserBundle' %}
<div class="col-sm-8">
    <div class="signup-form"><!--sign up form-->
        <div class="form-group row">
            <div class="col-sm-6">
                {{ form_start(form) }}
                {{ form_end(form) }}
            </div>
            <div class="col-sm-6">
                <div class="card">
                    <div class="card-body">
                        <img width="300" src="{{ asset('/uploads/'~ form.image.vars.data.url) }}" alt="" >
                    </div> <!-- end card-body-->
                </div> <!-- end card-->
            </div>
        </div>
    </div>
</div>